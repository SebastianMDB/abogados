---
import SectionContainer from "./SectionContainer.astro";
---

<SectionContainer id="educacion">
  <div class="container mx-auto p-8">
    <h1 class="text-3xl font-bold mb-6">Módulo de Educación</h1>
    <p class="text-gray-700 mb-8">
      Nuestro estudio ofrece servicios legales especializados para docentes,
      asistentes de la educación y sostenedores de establecimientos
      educacionales.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div
        class="bg-white p-6 rounded-lg shadow-md transition-transform transform hover:scale-105"
      >
        <h2 class="text-xl font-bold mb-4">Derecho Laboral</h2>
        <p class="text-gray-700">
          Brindamos asesoramiento en contratos laborales, representación en
          conflictos laborales y asistencia en despidos injustificados.
        </p>
      </div>
      <div
        class="bg-white p-6 rounded-lg shadow-md transition-transform transform hover:scale-105"
      >
        <h2 class="text-xl font-bold mb-4">Derecho Administrativo</h2>
        <p class="text-gray-700">
          Ofrecemos asesoría en normativas educativas, procesos administrativos
          y trámites de autorización para establecimientos educacionales.
        </p>
      </div>
      <div
        class="bg-white p-6 rounded-lg shadow-md transition-transform transform hover:scale-105"
      >
        <h2 class="text-xl font-bold mb-4">
          Derecho Civil y Responsabilidad Civil
        </h2>
        <p class="text-gray-700">
          Asistimos en la resolución de conflictos civiles en el ámbito
          educativo, como reclamaciones por daños y perjuicios.
        </p>
      </div>
    </div>
  </div>
</SectionContainer>
