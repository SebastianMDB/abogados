---
import SectionContainer from "./SectionContainer.astro";
---

<SectionContainer id="contacto" className="bg-gray-100 flex items-center justify-center h-screen">
  <div class="bg-white p-8 rounded shadow-md max-w-sm">
    <h1 class="text-2xl font-semibold mb-6 text-center">Envíanos tu caso</h1>

    <!-- Formulario de WhatsApp -->
    <form action="https://api.whatsapp.com/send" method="GET" target="_blank">
      <!-- Campo de Nombre -->
      <div class="mb-4">
        <label for="nombre" class="sr-only">Nombre:</label>
        <input type="text" id="nombre" name="text" placeholder="Nombre" class="w-full p-2 border border-black rounded focus:outline-none focus:border-blue-500">
      </div>

      <!-- Campo de Rut -->
      <div class="mb-4">
        <label for="rut" class="sr-only">RUT:</label>
        <input type="text" id="rut" name="text" placeholder="RUT" class="w-full p-2 border border-black rounded focus:outline-none focus:border-blue-500">
      </div>

      <!-- Campo de Correo -->
      <div class="mb-4">
        <label for="correo" class="sr-only">Correo:</label>
        <input type="email" id="correo" name="text" placeholder="Correo" class="w-full p-2 border border-black rounded focus:outline-none focus:border-blue-500">
      </div>

      <!-- Campo de Mensaje -->
      <div class="mb-4">
        <label for="mensaje" class="sr-only">Mensaje:</label>
        <textarea id="mensaje" name="text" placeholder="Mensaje" rows="4" class="w-full p-2 border border-black rounded focus:outline-none focus:border-blue-500"></textarea>
      </div>

      <!-- Botón de Enviar -->
      <div>
        <button type="submit" class="bg-black text-white px-4 py-2 rounded hover:bg-gray-800 focus:outline-none w-full">Enviar por WhatsApp</button>
      </div>
    </form>
  </div>

</SectionContainer>